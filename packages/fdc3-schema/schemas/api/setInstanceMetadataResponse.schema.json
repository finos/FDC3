			"title": "SetInstanceMetadata Error Response Payload",
			"type": "object",
			"properties": {
				"error": {
					"title": "SetInstanceMetadata Error Message",
					"oneOf": [
						{
							"$ref": "api.schema.json#/definitions/ResolveError"
						},
