{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "https://fdc3.finos.org/schemas/next/api/setInstanceMetadataResponse.schema.json",
	"type": "object",
	"title": "SetInstanceMetadata Response",
