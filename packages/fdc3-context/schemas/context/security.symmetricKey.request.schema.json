{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://fdc3.finos.org/schemas/next/context/symmetricKeyRequest.schema.json",
    "type": "object",
    "title": "Symmetric Key Request",
    "description": "A request to obtain a symmetric encryption key.",
    "allOf": [
        {
            "type": "object",
            "properties": {
                "type": {
                    "const": "fdc3.security.symmetricKey.request"
                },
                "id": {
                    "type": "object",
                    "description": "Optional identifier for the requested key.",
                    "properties": {
                        "kid": {
                            "type": "string",
                            "description": "Key ID to request a specific symmetric key."
                        }
                    },
                    "additionalProperties": true
                }
            },
            "required": [
                "type"
            ]
        },
        {
            "$ref": "context.schema.json#/definitions/BaseContext"
        }
    ],
    "examples": [
        {
            "type": "fdc3.security.symmetricKey.request"
        },
        {
            "type": "fdc3.security.symmetricKey.request",
            "id": {
                "kid": "channel-key-abc123"
            }
        }
    ]
}