{
  "name": "fdc3-conformance",
  "version": "3.0.0-alpha.2",
  "homepage": "https://fdc3.finos.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finos/FDC3.git"
  },
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "copy": "shx mkdir -p ./dist && shx cp -R static/* ./dist",
    "build": "vite build && npm run copy",
    "serve": "npx http-server ./dist -p 3001 -c-1 --cors",
    "dev": "npm run clean && npm run build && npm run serve",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@finos/fdc3": "3.0.0-alpha.2",
    "buffer": "^6.0.3",
    "chai": "^4.3.6",
    "mocha": "^10.0.0",
    "process": "^0.11.10",
    "source-map-support": "^0.5.21",
    "stream-browserify": "^3.0.0",
    "util": "^0.12.5"
  },
  "devDependencies": {
    "@rollup/plugin-inject": "^5.0.5",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.10",
    "ajv": "^8.17.1",
    "ajv-keywords": "^5.1.0",
    "http-server": "^14.1.1",
    "prettier": "3.4.1",
    "replace-in-file": "^6.3.5",
    "shx": "^0.3.4",
    "typescript": "^5.6.3",
    "vite": "^7.3.5",
    "vite-plugin-css-injected-by-js": "^4.0.1"
  },
  "engines": {
    "node": ">=22"
  }
}
