{
  "name": "@finos/fdc3-example-apps",
  "version": "3.0.0-alpha.2",
  "description": "FDC3 example web applications and a local App Directory server for Desktop Agent demos",
  "author": "Fintech Open Source Foundation (FINOS)",
  "homepage": "https://fdc3.finos.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finos/FDC3.git",
    "directory": "toolbox/fdc3-example-apps"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "fdc3-example-apps": "./bin/run.mjs"
  },
  "files": [
    "bin",
    "main.ts",
    "front-end-apps",
    "server-apps",
    "common",
    "directory/properties.json",
    "directory/static"
  ],
  "scripts": {
    "clean": "rimraf --glob \"directory/static/generated\" \"front-end-apps/*/.vite\" \"server-apps/*/.vite\" \"directory/.vite\"",
    "build": "tsc",
    "dev": "tsx main.ts",
    "start": "tsx main.ts",
    "prepack": "npm run clean"
  },
  "dependencies": {
    "@azure/msal-browser": "^4.12.0",
    "@finos/fdc3": "3.0.0-alpha.2",
    "@finos/fdc3-security": "3.0.0-alpha.2",
    "@jridgewell/trace-mapping": "^0.3.28",
    "@vitejs/plugin-react": "^4.7.0",
    "canonicalize": "^2.1.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.1",
    "express-rate-limit": "^7.5.0",
    "jose": "^6.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "uuid": "^14.0.1",
    "vite": "^7.3.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1"
  }
}