{
  "applications": [
    {
      "appId": "view-news-view-quote-intent-listener",
      "name": "View News + View Quote Intent Listener",
      "title": "View News + View Quote Intent Listener",
      "description": "Listens for the ViewNews intent only",
      "type": "web",
      "details": {
        "url": "http://localhost:4014/"
      },
      "hostManifests": {},
      "version": "1.0.0",
      "publisher": "FINOS",
      "categories": [
        "Intent Listening Demo"
      ],
      "icons": [
        {
          "src": "http://localhost:4014/icon.svg"
        }
      ],
      "interop": {
        "intents": {
          "listensFor": {
            "ViewNews": {
              "displayName": "View News",
              "contexts": [
                "fdc3.instrument"
              ]
            },
            "ViewQuote": {
              "displayName": "View Quote",
              "contexts": [
                "fdc3.instrument"
              ]
            }
          }
        }
      },
      "minimumAgentVersion": "2.0"
    }
  ],
  "message": "OK"
}
